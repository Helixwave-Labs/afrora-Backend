# --- Variables for the PostgreSQL Container (db service) ---
POSTGRES_DB=afrovogue_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# --- Variables for the FastAPI Container (api service) ---
DATABASE_URL=postgresql://postgres:password@db:5432/afrovogue_db

# FIXED: changed 'localhost' to 'redis'
REDIS_URL=redis://redis:6379

# A secret key for encoding JWT tokens.
JWT_SECRET=a_very_secret_and_long_random_string_for_jwt

# --- Phase 1 & 2: AWS S3 Storage Settings ---
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=your_bucket_name_here
# Optional CDN domain for CloudFront or custom domain links
# AWS_S3_CUSTOM_DOMAIN=cdn.afrovogue.com

# --- Phase 1: Stripe Payments ---
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- Phase 1: CORS allowed origins (comma-separated) ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Phase 3: Sentry Error Monitoring ---
SENTRY_DSN=your_sentry_dsn_here
